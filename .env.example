# OpenAI / Azure OpenAI (para Whisper e modelos de linguagem)
OPENAI_API_KEY=your_openai_api_key_here
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure Cognitive Services
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=brazilsouth
AZURE_VISION_KEY=your_azure_vision_key_here
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Azure Storage (para armazenamento seguro de dados sensíveis)
AZURE_STORAGE_CONNECTION_STRING=your_connection_string_here

# Caminhos dos modelos
YOLO_MODEL_PATH=models/yolov8_custom.pt
YOLO_CONFIG_PATH=models/yolov8_config.yaml
AUDIO_MODEL_PATH=models/audio_emotion_model.pkl

# Configurações de alerta
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_FROM=alerts@hospital.com
ALERT_EMAIL_TO=equipe_medica@hospital.com
ALERT_EMAIL_PASSWORD=your_email_password_here

# Log level
LOG_LEVEL=INFO

# Device
DEVICE=cuda
